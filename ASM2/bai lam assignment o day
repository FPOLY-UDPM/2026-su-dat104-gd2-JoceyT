----1.	Cho biết danh sách vắng học (sinh viên vắng (TrangThai = 'A'))
Select *
From DiemDanh as dd
Where dd.TrangThai = 'A'
----2. Đếm số buổi vắng theo từng sinh viên
Select 
dd.MASV
,Count(Case When dd.TrangThai = 'A' Then 1 End) as So_BVang
From DiemDanh as dd
Group By dd.MASV


----7.	Đếm số buổi vắng của từng sinh viên theo từng lớp
Select
dd.Lop
,dd.MASV
,Count(dd.TrangThai) as So_BVang
From dbo.DiemDanh dd
Where dd.TrangThai='A'
Group by dd.Lop,dd.MASV

-----8.	Tìm sinh viên có số buổi vắng > 3
Select
dd.Lop
,dd.MASV
,Count(dd.TrangThai) as So_BVang
From dbo.DiemDanh dd
Where dd.TrangThai='A'
Group by dd.Lop,dd.MASV
Having Count(dd.TrangThai) >3
Order By So_BVang ASC
-----9.	Liệt kê sinh viên có yêu cầu khôi phục điểm danh trùng với ngày KHÔNG bị vắng

SELECT 
    kp.MASV,
    kp.Lop,
    kp.NgayHoc,
    dd.TrangThai AS TrangThaiHienTai
FROM dbo.KhoiPhucDiemDanh kp
INNER JOIN dbo.DiemDanh dd 
    ON kp.MASV = dd.MaSV 
    AND kp.Lop = dd.Lop 
    AND kp.NgayHoc = dd.NgayHoc
WHERE dd.TrangThai <> 'A'; 

-----10.Cập nhật trạng thái điểm danh thành 'P' cho các sinh viên đã được duyệt khôi phục
UPDATE dd
SET dd.TrangThai = 'P'
FROM dbo.DiemDanh dd
INNER JOIN dbo.KhoiPhucDiemDanh kp 
    ON dd.MASV = kp.MASV 
    AND dd.Lop = kp.Lop 
    AND dd.NgayHoc = kp.NgayHoc
WHERE kp.Duyet = 1

-----11.	Tìm sinh viên có số buổi vắng nhiều nhất 
Select Top 1 dd.MASV
,Count(dd.TrangThai) So_BVang
From dbo.DiemDanh dd
Group by dd.MASV

----12.	Liệt kê tất cả điểm danh và yêu cầu khôi phục (nếu có) của lớp (ví dụ: DP21301)

Select
dd.Lop,dd.MASV,dd.NgayHoc,dd.TrangThai
    ,(Case kp.Duyet
        When 0 Then N'Khong Duyet'
        When 1 Then N'Duyet'
    End) as TT_Kp
From dbo.DiemDanh dd
Join dbo.ThongTinSV sv
on sv.MASV= dd.MASV
Left Join dbo.KhoiPhucDiemDanh kp
on kp.MASV=sv.MASV
And kp.Lop = dd.Lop
Where dd.Lop='DP21301'
Order by dd.NgayHoc, dd.MASV


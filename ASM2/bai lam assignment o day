----15.	Gắn nhãn trạng thái khôi phục điểm danh (nếu … thì …)


Select*
(Case 
    When Duyet = 1 and NoiDung_GiangVien Is Not Null 
        Then ' Đã duyệt và phản hồi'
    When Duyet = 1 and 
        (NoiDung_GiangVien Is Null 
            Or
        NoiDung_GiangVien = ' ') 
        Then N'Đã duyệt- Chờ phản hồi'
    When Duyet = 0 
        Then N'Đang chờ xét'
    Else N'KHÔNG XÁC ĐỊNH'
End) As TT_Kp
From dbo.KhoiPhucDiemDanh

